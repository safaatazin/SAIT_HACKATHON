# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=*

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=room-frames

# AI vision (set AI_PROVIDER to openai | gemini | anthropic)
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.0-flash
ANTHROPIC_API_KEY=
ANTHROPIC_VISION_MODEL=claude-3-5-haiku-latest

# Image change detection thresholds (percent difference)
DIFF_IGNORE_THRESHOLD=8.0
DIFF_SAVE_ONLY_THRESHOLD=18.0
